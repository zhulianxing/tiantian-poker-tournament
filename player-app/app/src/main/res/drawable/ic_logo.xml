<?xml version="1.0" encoding="utf-8"?>
<!-- 天天扑克锦标赛 主 Logo（与网站 public/assets/logo.svg 一致）：金色筹码 + 黑桃 -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="128dp"
    android:height="128dp"
    android:viewportWidth="128"
    android:viewportHeight="128">

    <!-- 筹码外圈（金色渐变） -->
    <path android:pathData="M64,2 A62,62 0 1,1 64,126 A62,62 0 1,1 64,2 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="128" android:endY="128">
                <item android:offset="0" android:color="#FFFFE87C" />
                <item android:offset="0.45" android:color="#FFFFD700" />
                <item android:offset="0.75" android:color="#FFC9A227" />
                <item android:offset="1" android:color="#FF8A6D1A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 轮圈凹槽 ×8（深色） -->
    <group android:pivotX="64" android:pivotY="64">
        <group android:rotation="22.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="67.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="112.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="157.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="202.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="247.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="292.5" android:pivotX="64" android:pivotY="64">
            <path android:fillColor="#0A0A0F" android:pathData="M61,3 h6 a3,3 0 0 1 3,3 v10 a3,3 0 0 1 -3,3 h-6 a3,3 0 0 1 -3,-3 V6 a3,3 0 0 1 3,-3 z" />
        </group>
        <group android:rotation="337.5" android:pivotX="64" android:pivotY="64">
