        </group>
    </group>

    <!-- 内盘（径向深色渐变） -->
    <path android:pathData="M64,19 A45,45 0 1,1 64,109 A45,45 0 1,1 64,19 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="64" android:centerY="53.2"
                android:gradientRadius="76.5">
                <item android:offset="0" android:color="#FF20202C" />
                <item android:offset="1" android:color="#FF0A0A0F" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- 内盘描边 -->
    <path
        android:pathData="M64,19 A45,45 0 1,1 64,109 A45,45 0 1,1 64,19 Z"
        android:fillColor="#00000000"
        android:strokeColor="#C9A227"
        android:strokeAlpha="0.6"
        android:strokeWidth="1.5" />

    <!-- 黑桃（金色渐变） -->
